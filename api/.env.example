# =============================================================================
# LISSAFI-P — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS COMMITTER .env dans Git
# =============================================================================

# --- Environnement -----------------------------------------------------------
NODE_ENV=development           # development | staging | production
PORT=3000
API_VERSION=v1
APP_NAME=LISSAFI-P
BASE_URL=http://localhost:3000

# --- Base de données PostgreSQL ----------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lissafi_db
DB_USER=lissafi_user
DB_PASSWORD=your_strong_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false                   # true en production (Railway, Render)

# --- Redis (cache + sessions) ------------------------------------------------
REDISHOST=localhost
REDISPORT=6379
REDISPASSWORD=                # laisser vide si pas de password local
REDIS_DB=0

# --- JWT Authentification ----------------------------------------------------
JWT_ACCESS_SECRET=change_me_to_64_random_chars_minimum_access
JWT_REFRESH_SECRET=change_me_to_64_random_chars_minimum_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- SMS / OTP (Twilio) ------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+12XXXXXXXXX
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5

# --- Firebase Cloud Messaging (notifications push) ---------------------------
FIREBASE_PROJECT_ID=lissafi-p-app
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@lissafi-p-app.iam.gserviceaccount.com

# --- Stockage fichiers (AWS S3 ou Cloudflare R2) ----------------------------
STORAGE_PROVIDER=cloudflare_r2  # aws_s3 | cloudflare_r2
S3_BUCKET_NAME=lissafi-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com  # R2 uniquement

# --- Paiement Mobile Money ---------------------------------------------------
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_subscription_key
MTN_MOMO_API_USER=your_api_user
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_ENVIRONMENT=sandbox   # sandbox | production

ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/cm/v1
ORANGE_MONEY_CLIENT_ID=your_client_id
ORANGE_MONEY_CLIENT_SECRET=your_client_secret
ORANGE_MONEY_MERCHANT_KEY=your_merchant_key

# --- Boutique en ligne -------------------------------------------------------
BOUTIQUE_BASE_URL=https://lissafi.cm/boutique

# --- Sécurité ----------------------------------------------------------------
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_MAX=10         # tentatives de connexion max / 15 min

# --- Logging -----------------------------------------------------------------
LOG_LEVEL=debug                # error | warn | info | debug
LOG_DIR=./logs

# --- Limites plan FREE (contrôle applicatif) ---------------------------------
FREE_MAX_OPERATIONS_PER_MONTH=30
FREE_MAX_PRODUCTS=20
FREE_MAX_CLIENTS=10
FREE_MAX_SMS_PER_MONTH=0
PRO_MAX_SMS_PER_MONTH=20
