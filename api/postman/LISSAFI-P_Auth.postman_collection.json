                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.be.true;",
                  "});",
                  "pm.test('data contient userId et identifier', () => {",
                  "  const { data } = pm.response.json();",
                  "  pm.expect(data).to.have.property('userId');",
                  "  pm.expect(data).to.have.property('identifier');",
                  "  // Sauvegarder pour les requêtes suivantes",
                  "  pm.environment.set('userId', data.userId);",
                  "  pm.environment.set('identifier', data.identifier);",
                  "  console.log('✔ userId sauvegardé :', data.userId);",
                  "  console.log('✔ identifier sauvegardé :', data.identifier);",
                  "});"
                ]
